# ================================
# Ground Protection API Configuration
# ================================

APP_NAME="Ground Protection API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8000

# Frontend URL للـ CORS
FRONTEND_URL=http://localhost:5173

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# ================================
# Database Configuration
# ================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ground_protection
DB_USERNAME=root
DB_PASSWORD=

# ================================
# Cache & Session
# ================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=gp_

# ================================
# Sanctum Configuration
# ================================
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173
SANCTUM_TOKEN_EXPIRATION=10080

# ================================
# Logging
# ================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ================================
# Mail Configuration
# ================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@ground-eg.com"
MAIL_FROM_NAME="${APP_NAME}"
# البريد الإلكتروني الذي يستقبل إشعارات رسائل التواصل والطلبات
MAIL_ADMIN_EMAIL="info@ground-eg.com"

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5

# ================================
# Maintenance Mode
# ================================
MAINTENANCE_MODE=false
MAINTENANCE_SECRET=

# ================================
# API Settings
# ================================
API_VERSION=v1
PAGINATION_PER_PAGE=15

# ================================
# File Upload
# ================================
MAX_UPLOAD_SIZE=10240
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# ================================
# Redis (Optional)
# ================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ================================
# AWS (Optional)
# ================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
