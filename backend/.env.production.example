# ===========================================
# Ground Protection API - Production Environment
# ===========================================
# الاستضافة: https://ground-eg.com
# تاريخ النشر: 2026-01-14
# ===========================================
# ⚠️ هذا الملف للنسخ على الخادم فقط - لا تستخدمه محلياً
# ⚠️ على الخادم: cp .env.production.example .env
# ===========================================

# ===========================================
# Application Settings
# ===========================================
APP_NAME="Ground Protection API"
APP_ENV=production
APP_DEBUG=false
APP_KEY=  # يتم إنشاؤه تلقائياً بـ: php artisan key:generate
APP_URL=https://ground-eg.com

# ===========================================
# Frontend URL
# ===========================================
FRONTEND_URL=https://ground-eg.com

# ===========================================
# Database Configuration
# ===========================================
# ⚠️ هذه البيانات من لوحة التحكم cPanel
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=grounde2_ground_eg_db
DB_USERNAME=grounde2_ground_eg_user
DB_PASSWORD=  # كلمة مرور قوية من cPanel

# ===========================================
# Mail Configuration
# ===========================================
# ⚠️ SMTP من الاستضافة
MAIL_MAILER=smtp
MAIL_HOST=mail.ground-eg.com
MAIL_PORT=587
MAIL_USERNAME=info@ground-eg.com
MAIL_PASSWORD=  # كلمة مرور SMTP من الاستضافة
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@ground-eg.com
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# Security Settings
# ===========================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ===========================================
# Sanctum Authentication
# ===========================================
# ⚠️ فارغ لأننا نستخدم Bearer Tokens فقط
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_EXPIRATION=1440  # 24 ساعة (بالدقائق)
SANCTUM_TOKEN_PREFIX=gp_

# ===========================================
# CORS Settings
# ===========================================
# مسموح لـ Frontend فقط
FRONTEND_CORS_ORIGINS=${FRONTEND_URL}

# ===========================================
# Cache & Queue
# ===========================================
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ===========================================
# Logging
# ===========================================
LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# ===========================================
# File System
# ===========================================
FILESYSTEM_DISK=public

# ===========================================
# API Configuration
# ===========================================
API_VERSION=v1
API_PAGINATION_PER_PAGE=15

# ===========================================
# Timezone & Locale
# ===========================================
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar

# ===========================================
# Optional: Google Maps API (إذا كنت تستخدمه)
# ===========================================
# GOOGLE_MAPS_API_KEY=

# ===========================================
# Optional: Analytics
# ===========================================
# GOOGLE_ANALYTICS_ID=
