# ================================
# Ground Tech - React SPA Routing
# ================================
# Apache Configuration for Single Page Application

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Force HTTPS (Production)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Serve existing files/directories directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Fallback to index.html for all other routes (SPA)
  RewriteRule . /index.html [L]
</IfModule>

# ================================
# Error Pages
# ================================
<IfModule mod_dir.c>
  DirectoryIndex index.html
</IfModule>

# Custom error pages redirect to index.html (SPA handles routing)
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html
ErrorDocument 500 /index.html

# ================================
# Security Headers
# ================================
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Clickjacking protection
  Header set X-Frame-Options "SAMEORIGIN"
  
  # XSS Protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ================================
# GZIP Compression
# ================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ================================
# Browser Caching
# ================================
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images - 1 year
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS and JavaScript - 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Fonts - 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # HTML - 1 hour
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ================================
# MIME Types
# ================================
<IfModule mod_mime.c>
  AddType application/javascript js
  AddType text/css css
</IfModule>

# ================================
# File Access Control
# ================================
# Deny access to hidden files (except .well-known for SSL)
<FilesMatch "^\.(?!well-known)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
